# ---------------------------------------------------------------------------
# Copilot — AI Ad Manager  ·  Environment template
# Copy to `.env.local` and fill in real values. NEVER commit the filled file.
# `.env.local` is gitignored; this example (names only, no secrets) is safe.
# ---------------------------------------------------------------------------

# --- Database (Supabase Postgres, transaction pooler) -----------------------
# Use the pooled connection string; pgbouncer=true is REQUIRED for the
# transaction pooler (disables prepared statements).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# --- Auth (Clerk — source of truth for identity) ----------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=   # Clerk publishable key (safe for client)
CLERK_SECRET_KEY=                    # Clerk secret key (server only)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
# REMOVED — Clerk replaces these: ADMIN_PASSWORD, SESSION_SECRET

# --- Crypto & cron ----------------------------------------------------------
CREDS_SECRET=              # AES-256-GCM key for creds at rest. NEVER ROTATE.
CRON_SECRET=               # Bearer token guarding /api/cron

# --- AI inference (Cloudflare Workers AI) -----------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AUTH_TOKEN=

# --- Meta (Facebook) Ads ----------------------------------------------------
META_ACCESS_TOKEN=         # system-user / long-lived token
META_AD_ACCOUNT_ID=        # numeric id (code prefixes act_)
META_PAGE_ID=

# --- Google Drive (carousel FOLDER links) -----------------------------------
# Read-only Drive API key (server only). Lets a shared folder link expand into
# its images for a carousel. Restrict it in Google Cloud to the Drive API,
# read-only. Only lists folders shared "Anyone with the link" — no private data.
# If unset, folder links are simply unsupported; individual image links still work.
GOOGLE_DRIVE_API_KEY=

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=            # if unset, email falls back to mock + alert
EMAIL_FROM=                # verified sender address
NOTIFY_EMAIL=              # operator alert recipient

# --- Capacity tuning (optional; sensible defaults in lib/capacity.ts) -------
# CAPACITY_MAX_AI_CALLS_PER_DAY=250
# CAPACITY_MAX_DB_BYTES=524288000
# CAPACITY_RESEARCH_SOFT_CEILING=40
