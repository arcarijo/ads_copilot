# Copy to .env.production.secrets and fill in the real value from the
# Supabase dashboard (session-mode pooler, :5432 — not the :6543
# transaction-mode pooler). This file is gitignored; never commit the real one.
#
# Used by `npm run prisma:prod -- <prisma subcommand>`, e.g.:
#   npm run prisma:prod -- migrate deploy
#   npm run prisma:prod -- migrate resolve --applied <migration-name>
DATABASE_URL="postgresql://postgres:<password>@<host>:5432/postgres"
