# Copy to .env.preview.secrets and fill in the real value from the Vercel
# dashboard (Preview environment's DATABASE_URL — session-mode pooler, :5432,
# not the :6543 transaction-mode pooler). This file is gitignored; never
# commit the real one.
#
# Used by `npm run prisma:preview -- <prisma subcommand>`, e.g.:
#   npm run prisma:preview -- migrate resolve --applied <migration-name>
#   npm run prisma:preview -- migrate deploy
DATABASE_URL="postgresql://postgres:<password>@<host>:5432/postgres"
