# Red-team cycle secrets. Copy to `.env.redteam` (gitignored) and fill in.
# Everything here is STAGING-only. The harness aborts if it sees a prod value.

# The preview URL to scan (a "-git-" Vercel preview alias). Can also be passed as --target=.
REDTEAM_TARGET=https://ads-copilot-git-<branch>-arcarijo.vercel.app

# Vercel → Project Settings → Deployment Protection → "Protection Bypass for Automation".
# Lets ZAP/Nuclei/HTTP checks clear the auth wall. Never logged.
VERCEL_AUTOMATION_BYPASS_SECRET=

# Staging Clerk secret key (MUST be sk_test — the harness refuses sk_live).
CLERK_SECRET_KEY=sk_test_...

# Two users that already exist in the STAGING Clerk instance:
#   - admin: publicMetadata.role = "admin"
#   - member: no admin role
REDTEAM_ADMIN_EMAIL=admin@example.com
REDTEAM_MEMBER_EMAIL=member@example.com

# Staging Supabase pooler URL (must contain the staging ref lprydieusipocvsikkqb).
# Used only to seed/clean up synthetic `zzz-redteam-` tenants.
DATABASE_URL=postgresql://postgres.lprydieusipocvsikkqb:<password>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional: extra allowed target hosts (comma-separated), e.g. a custom staging domain.
# REDTEAM_ALLOW_HOSTS=staging.example.com
# Optional: disable the long ZAP active scan at T2 (REDTEAM_ZAP_FULL=0), or tune its timeout.
# REDTEAM_ZAP_FULL=0
# REDTEAM_ZAP_TIMEOUT_MS=900000
